---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/ajanlat/Hero';
import Stats from '../../components/ajanlat/Stats';
import Guarantees from '../../components/ajanlat/Guarantees';
import Pricing from '../../components/ajanlat/Pricing';
import Process from '../../components/ajanlat/Process';
import { getOffers } from '../../lib/notion';

export async function getStaticPaths() {
  const offers = await getOffers();

  return offers.map((offer) => {
    const { visitors, customers, avgOrderValue, adSpend } = offer;
    
    // CR Calculation
    const currentCR = visitors > 0 ? (customers / visitors) * 100 : 0;
    const lostSales = visitors - customers;
    const currentRevenue = customers * avgOrderValue;

    const projections = [1, 3, 5, 10].map(increasePct => {
      const newCR = currentCR + increasePct;
      const newCustomers = Math.round(visitors * (newCR / 100));
      const newTotalRevenue = newCustomers * avgOrderValue;
      const extraRevenue = newTotalRevenue - currentRevenue;

      return {
        increase: `+${increasePct}%`,
        extraRevenue: new Intl.NumberFormat('hu-HU', { style: 'currency', currency: 'HUF', maximumFractionDigits: 0 }).format(extraRevenue),
        total: new Intl.NumberFormat('hu-HU', { style: 'currency', currency: 'HUF', maximumFractionDigits: 0 }).format(newTotalRevenue)
      };
    });

    // Calculate ROI for +1% scenario
    // Projections[0] is +1%
    const extraRev1Pct = Math.round(visitors * ((currentCR + 1) / 100)) * avgOrderValue - currentRevenue;
    const roi = adSpend > 0 ? Math.round((extraRev1Pct / adSpend) * 100) : 0;

    return {
      params: { slug: offer.slug },
      props: {
        clientName: offer.clientName,
        companyName: offer.companyName,
        heroImage: offer.heroImage,
        stats: {
          visitors: visitors,
          conversionRate: Number(currentCR.toFixed(1)),
          avgOrderValue: avgOrderValue,
          adSpend: adSpend,
          lostSales: lostSales,
          projections: projections,
          roi: `${roi}%`
        },
        pricing: {
          upfront: "158.500 Ft",
          delivery: "158.500 Ft",
          timeline: "7 munkanapon belül",
          features: [
            "1 komplett landing oldal",
            "Profi, konverzió-fókuszú szövegírás",
            "Analitikai eszközök telepítése és monitoring",
            "90 napig havi 1 statisztikai riport és fejlesztési javaslat",
            "Ingyenes és korlátlan tárhely 12 hónapig",
            "Korlátalan módosítás 90 napig, egyszerre egy aktív kérés",
            "Átlagosan 3 munkanapon belüli módosítás"
          ]
        }
      }
    };
  });
}

const { clientName, companyName, heroImage, stats, pricing } = Astro.props;
---

<Layout title={`Személyre szabott CRO ajánlat - ${clientName} (${companyName})`}>
  <style is:global>
    @import url('https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,200..800&family=Montserrat:wght@100..900&display=swap');
    
    .font-heading {
      font-family: 'Bricolage Grotesque', sans-serif;
    }
    .font-body {
      font-family: 'Montserrat', sans-serif;
    }
  </style>

  <div class="bg-[#000002] min-h-screen text-[#e5dce6] font-body selection:bg-[#ea580c]/30">
    <main class="w-[95%] md:w-[70%] max-w-none mx-auto px-4 py-8 md:py-16 space-y-12 md:space-y-16">
      <Hero clientName={clientName} companyName={companyName} heroImage={heroImage} />
      <Stats stats={stats} />
      <Guarantees />
      <Pricing pricing={pricing} />
      <Process />
    </main>
  </div>
</Layout>
