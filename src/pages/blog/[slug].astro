---
import Layout from '../../layouts/Layout.astro';
import { getPublishedBlogPosts } from '../../lib/notion';
import { Image, getImage } from 'astro:assets';
import { marked } from 'marked';
import { load } from 'cheerio';
import { MousePointer2 } from 'lucide-react';
import DefaultCloser from '../../components/ingyenes-audit/Closer';
import MainWebsiteCloser from '../../components/main-website/Closer';
import Stats from '../../components/ajanlat/Stats';

export async function getStaticPaths() {
  const posts = await getPublishedBlogPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const contentHtml = await marked.parse(post.content || '');

// Process HTML to optimize images using Astro's getImage
const $ = load(contentHtml);
let customReadingTime = null;

const isNewAudit = post.type === 'Audit' && post.publishedDate >= new Date('2026-03-20T00:00:00.000Z');

let statsData = null;

if (isNewAudit) {
    const parseInterval = (text: string) => {
      if (!text || text === '0') return 0;
      let cleaned = text.replace(/\s+/g, '');
      cleaned = cleaned.replace(/\./g, '');
      const matches = cleaned.match(/\d+/g);
      if (!matches) return 0;
      const numbers = matches.map(Number);
      if (numbers.length === 1) return numbers[0];
      return (numbers[0] + numbers[1]) / 2;
    };

    const visitors = parseInterval(post.visitors);
    const customers = parseInterval(post.customers);
    const avgOrderValue = parseInterval(post.aov);
    const adSpend = parseInterval(post.adSpend);

    const currentCR = visitors > 0 ? (customers / visitors) * 100 : 0;
    const lostSales = visitors - customers;
    const currentRevenue = customers * avgOrderValue;

    const projections = [1, 3, 5, 10].map(increasePct => {
      const newCR = currentCR + increasePct;
      const newCustomers = Math.round(visitors * (newCR / 100));
      const newTotalRevenue = newCustomers * avgOrderValue;
      const extraRevenue = newTotalRevenue - currentRevenue;

      return {
        increase: `+${increasePct}%`,
        extraRevenue: new Intl.NumberFormat('hu-HU', { style: 'currency', currency: 'HUF', maximumFractionDigits: 0 }).format(extraRevenue),
        total: new Intl.NumberFormat('hu-HU', { style: 'currency', currency: 'HUF', maximumFractionDigits: 0 }).format(newTotalRevenue)
      };
    });

    const extraRev1Pct = Math.round(visitors * ((currentCR + 1) / 100)) * avgOrderValue - currentRevenue;
    const investmentCost = 317000;
    const roi = extraRev1Pct > 0 ? Math.floor((extraRev1Pct / investmentCost) * 100) : 0;

    statsData = {
      visitors: visitors,
      conversionRate: Number(currentCR.toFixed(1)),
      avgOrderValue: avgOrderValue,
      adSpend: adSpend,
      lostSales: lostSales,
      projections: projections,
      roi: `${roi}%`
    };
}

if (post.type === 'Audit') {
  // 2. Embed HTML blocks
  $('pre code.language-html').each((i, el) => {
    const rawHtml = $(el).text();
    $(el).parent().replaceWith(rawHtml);
  });

  // 4. Extract reading time
  $('p').each((i, el) => {
    const text = $(el).text();
    if (text.includes('Olvasási idő:')) {
      customReadingTime = text;
      $(el).remove();
    }
  });

  // 5. Format signature
  let signatureTextsFound = false;
  let $name, $role, $button, $img;

  $('p, a').each((i, el) => {
    const $el = $(el);
    const text = $el.text().trim();
    if (text === 'Bogdán Norbert') {
      $name = $el;
      signatureTextsFound = true;
    } else if (text === 'CRO Specialista | DesignTér') {
      $role = $el;
    } else if (text.includes('Beszéljünk 15 percet')) {
      $button = $el;
      // If it's a paragraph containing the text, or a link, we want to make sure it looks like a button
      const $a = $el.is('a') ? $el : ($el.find('a').length ? $el.find('a').first() : null);
      
      if ($a) {
        $a.addClass('inline-flex justify-center items-center w-full lg:w-auto bg-brand-accent text-white font-semibold px-8 py-3.5 rounded-xl hover:bg-brand-900 transition-colors shadow-sm decoration-transparent');
        if (!$a.attr('href')) {
          $a.attr('href', 'https://cal.com/designter/15perc');
          $a.attr('target', '_blank');
          $a.attr('rel', 'noopener noreferrer');
        }
      } else {
        // Create a link if it doesn't exist
        const $newLink = $(`<a href="https://cal.com/designter/15perc" target="_blank" rel="noopener noreferrer" class="inline-flex justify-center items-center w-full lg:w-auto bg-brand-accent text-white font-semibold px-8 py-3.5 rounded-xl hover:bg-brand-900 transition-colors shadow-sm decoration-transparent">${text}</a>`);
        $el.replaceWith($newLink);
        $button = $newLink;
      }
    }
  });

  if (signatureTextsFound) {
    // Assume the image is immediately preceding the name, or fallback to the last image in the document
    $img = $name.prev('img');
    if (!$img.length) {
       $img = $name.prev().find('img');
    }
    if (!$img.length) {
       $img = $('img').last(); 
    }

    const $outerContainer = $('<div class="my-16 flex flex-col gap-12 w-full"></div>');

    // Add Offer Headline and Subheadline
    const $offerHeader = $(`
      <div class="not-prose flex flex-col gap-4 text-center sm:text-left">
        <h2 class="text-2xl sm:text-3xl font-bold text-brand-900 leading-tight m-0">Szeretnéd, hogy elkészítsem neked azt az optimalizált verziót, amivel akár 3x több leadet szerezhetsz?</h2>
        <p class="text-lg text-gray-600 leading-relaxed m-0">A kész tervet 48 órán belül átadom. Ha nem vagy elégedett az eredménnyel, nem fizetsz semmit. Ez 0 rizikó számodra, csak tiszta profit-potenciál.</p>
      </div>
    `);
    $outerContainer.append($offerHeader);

    const $signatureContainer = $('<div class="not-prose p-6 sm:p-8 bg-gray-50 rounded-3xl border border-gray-100 shadow-sm w-full flex flex-col gap-8 sm:gap-10"></div>');

    const $mainRow = $('<div class="flex flex-col lg:flex-row items-center justify-between gap-6 w-full"></div>');
    const $profileGroup = $('<div class="flex flex-col sm:flex-row items-center gap-6 sm:gap-8"></div>');

    if ($img.length) {
      $img.attr('data-signature', 'true');
      const $imgContainer = $('<div class="flex-shrink-0 w-24 h-24 sm:w-28 sm:h-28 rounded-full overflow-hidden border-4 border-white shadow-md"></div>');
      // Clone the img so we can place it in our new container
      $imgContainer.append($img.clone());
      $profileGroup.append($imgContainer);
      $img.remove(); // Remove original
    }

    const $textWrapper = $('<div class="flex flex-col items-center sm:items-start text-center sm:text-left"></div>');

    if ($name) {
      $name.addClass('text-2xl font-bold text-gray-900 mb-1 mt-0');
      $textWrapper.append($name.clone());
      $name.remove();
    }
    if ($role) {
      $role.addClass('text-base text-gray-500 m-0');
      $textWrapper.append($role.clone());
      $role.remove();
    }
    
    $profileGroup.append($textWrapper);
    $mainRow.append($profileGroup);
    
    if ($button) {
      // $button is already the link or a styled element from the loop above
      const $finalButton = $button.is('a') ? $button : ($button.find('a').length ? $button.find('a').first() : $button);
      $mainRow.append($finalButton.clone());
      $button.remove();
    }

    $signatureContainer.append($mainRow);

    // Add multiple FUD reductions
    const $fudSection = $(`
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 w-full">
        <div class="flex items-center gap-3 p-4 bg-green-500/10 rounded-xl border border-green-500/20">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-600 flex-shrink-0"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          <p class="text-sm font-bold text-green-700 m-0 leading-tight">100% ingyenes konzultáció</p>
        </div>
        <div class="flex items-center gap-3 p-4 bg-green-500/10 rounded-xl border border-green-500/20">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-600 flex-shrink-0"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <p class="text-sm font-bold text-green-700 m-0 leading-tight">100% elégedettségi garancia</p>
        </div>
        <div class="flex items-center gap-3 p-4 bg-green-500/10 rounded-xl border border-green-500/20">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-600 flex-shrink-0"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <p class="text-sm font-bold text-green-700 m-0 leading-tight">48 órás szállítás</p>
        </div>
      </div>
    `);

    $signatureContainer.append($fudSection);
    $outerContainer.append($signatureContainer);
    
    // Add Testimonials below signature section
    const googleLogoHtml = `<svg viewBox="0 0 24 24" class="w-4 h-4 mr-1" xmlns="http://www.w3.org/2000/svg"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4" /><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853" /><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05" /><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335" /></svg>`;
    const starHtml = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 fill-current"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`;

    const reviews = [
      { name: "E. Renáta.", company: "Terápiás szakember", result: "6x CR", text: "Nem csak egy gyönyörű weboldalt kaptam, hanem egy rendszert, ami helyettem dolgozik. Az ügyfeleim maguktól foglalnak és fizetnek. Én pedig végre csak a munkámra figyelhetek. Imádom! Köszönöm." },
      { name: "M. Edit.", company: "Kozmetikai szalon tulajdonos", result: "Tele naptár", text: "Fogalmam sem volt, hogy hogyan működik egy weboldal, de Norbi és Lili úgy vittek végig mindenen, hogy egy percig sem stresszeltem. Tényleg figyeltek rám, és az eredmény is ezt tükrözi." },
      { name: "Ő. Szilvia", company: "Magántanár", result: "3,5x CR", text: "Egyedi ötlettel jöttem, nem sablonos weboldalt akartam. A folyamat során mindig tudtam, hogy hol tartunk, mit kell tennem és minden részlet a helyére került, pedig egyáltalán nem értek ezekhez a dolgokhoz. Remek élmény volt." }
    ];

    const $testimonials = $(`
      <div class="not-prose p-0 rounded-3xl border-0">
        <h2 class="text-2xl sm:text-3xl font-bold text-left text-brand-900 mb-10">
          Vállalkozók, akik már nem aggódnak a következő ügyfél miatt.
        </h2>
        <div class="flex flex-col gap-6">
          ${reviews.map(review => `
            <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
              <div class="flex items-center gap-1 mb-3 text-yellow-500">
                ${starHtml}${starHtml}${starHtml}${starHtml}${starHtml}
              </div>
              <p class="text-gray-700 mb-6 font-medium text-sm sm:text-base">"${review.text}"</p>
              <div class="flex items-center justify-between border-t border-gray-100 pt-4">
                <div>
                  <p class="font-bold text-brand-900 text-sm m-0">${review.name}</p>
                  <p class="text-xs text-gray-500 m-0">${review.company}</p>
                </div>
                <div class="text-right flex flex-col items-end">
                  <span class="block text-green-600 font-bold text-sm bg-green-50 px-2 py-1 rounded mb-2">
                    ${review.result}
                  </span>
                  <div class="flex items-center bg-white border border-gray-200 rounded-full px-2 py-0.5 shadow-sm">
                     ${googleLogoHtml}
                     <span class="text-[10px] font-semibold text-gray-600 uppercase tracking-wide">Ellenőrzött</span>
                  </div>
                </div>
              </div>
            </div>
          `).join('')}
        </div>
      </div>
    `);
    $outerContainer.append($testimonials);
    
    // Move signature above the FAQ or below the specific intro sentence
    let $faqHeading = null;
    $('h3').each((i, el) => {
      const $h3 = $(el);
      const $next = $h3.next();
      if ($next.is('pre') && $next.find('code').length > 0) {
        $faqHeading = $h3;
        return false;
      }
    });

    let $introSentence = null;
    $('p, strong').each((i, el) => {
      if ($(el).text().includes('vizuális prototípust is kifejezetten nektek')) {
        $introSentence = $(el).closest('p');
        return false;
      }
    });

    if ($faqHeading) {
      $outerContainer.insertBefore($faqHeading);
    } else if ($introSentence && $introSentence.length) {
      $outerContainer.insertAfter($introSentence);
    } else {
      $('body').append($outerContainer);
    }
  }

  // 6. Format FAQ Toggles (H3 followed by indented text parsed as code block)
  let faqHeadingAdded = false;
  $('h3').each((i, el) => {
    const $h3 = $(el);
    const $next = $h3.next();
    
    // Check if the next element is a code block
    if ($next.is('pre') && $next.find('code').length > 0) {
      if (!faqHeadingAdded) {
        $h3.before('<h2 class="not-prose text-2xl sm:text-3xl font-bold text-brand-900 leading-tight mb-8 mt-12 text-center sm:text-left">Valamit nem értettél? Talán itt választ kapsz rá:</h2>');
        faqHeadingAdded = true;
      }
      
      const questionHtml = $h3.html();
      const answerText = $next.find('code').text().trim();
      
      const $details = $(`
        <details class="group bg-white rounded-2xl shadow-sm border border-gray-100 p-6 mb-4 cursor-pointer [&_summary::-webkit-details-marker]:hidden not-prose">
          <summary class="flex items-center justify-between font-bold text-lg text-brand-900 list-none hover:text-brand-accent transition-colors outline-none">
            <span class="pr-4">${questionHtml}</span>
            <span class="flex-shrink-0 transition-transform duration-300 group-open:-rotate-180 bg-gray-50 p-2 rounded-full group-hover:bg-brand-50">
              <svg fill="none" height="20" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="20" class="text-brand-accent"><path d="M6 9l6 6 6-6"></path></svg>
            </span>
          </summary>
          <div class="text-gray-600 mt-4 leading-relaxed pl-2 border-l-2 border-brand-accent/20">
            ${answerText}
          </div>
        </details>
      `);
      
      $h3.replaceWith($details);
      $next.remove();
    }
  });
}

const imgElements = $('img');

await Promise.all(imgElements.map(async (i, el) => {
  const src = $(el).attr('src');
  if (!src) return;

  const isSignature = $(el).attr('data-signature') === 'true';

  try {
    const optimized = await getImage({
      src: src,
      format: 'webp',
      width: isSignature ? 256 : 800, // Resize to a reasonable width for blog content
      height: isSignature ? 256 : undefined, // Maintain aspect ratio
    });
    
    $(el).attr('src', optimized.src);
    $(el).attr('loading', 'lazy');
    $(el).attr('decoding', 'async');
    // Add Tailwind classes for styling
    if (isSignature) {
      $(el).addClass('w-full h-full object-cover');
    } else {
      $(el).addClass('rounded-xl shadow-lg my-8 w-full h-auto object-cover');
    }
    // Remove fixed dimensions if any
    $(el).removeAttr('width');
    $(el).removeAttr('height');
  } catch (e) {
    console.error(`Failed to optimize image: ${src}`, e);
    // Fallback: just add styling
    $(el).attr('loading', 'lazy');
    if (isSignature) {
      $(el).addClass('w-full h-full object-cover');
    } else {
      $(el).addClass('rounded-xl shadow-lg my-8 w-full h-auto object-cover');
    }
  }
}).get());

const optimizedContent = $('body').html() || contentHtml; // Extract body content or fallback

const title = `${post.title} - DesignTér Blog`;
const description = post.description;
const image = post.previewImage || post.coverImage;
---

<Layout title={title} description={description} image={image}>
  <header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-100 py-4">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex justify-between items-center">
      <a href="/blog" class="flex items-center gap-2 group text-gray-600 hover:text-brand-900 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        <span class="font-medium">Vissza a blogra</span>
      </a>
      <a href="/" class="flex items-center gap-2">
        <div class="bg-brand-accent p-1.5 rounded-lg">
          <MousePointer2 className="w-5 h-5 text-white" />
        </div>
        <span class="text-lg font-bold tracking-tight text-brand-900 hidden sm:inline">DesignTér</span>
      </a>
    </div>
  </header>

  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <article>
      <header class={`mb-8 ${post.type === 'Audit' ? 'text-left' : 'text-center'}`}>
        <div class={`flex items-center ${post.type === 'Audit' ? 'justify-start' : 'justify-center'} gap-4 text-sm text-gray-500 mb-4`}>
          <time datetime={post.publishedDate.toISOString()}>
            {post.publishedDate.toLocaleDateString('hu-HU', { 
              year: 'numeric', 
              month: 'long', 
              day: 'numeric' 
            })}
          </time>
          {post.type !== 'Audit' ? (
            <>
              <span>•</span>
              <span>{Math.ceil(post.content.split(' ').length / 200)} perc olvasás</span>
            </>
          ) : (
            customReadingTime && (
              <span class="bg-brand-accent/10 text-brand-900 font-medium px-3 py-1 rounded-full text-xs">
                {customReadingTime}
              </span>
            )
          )}
        </div>
        <h1 class={`text-3xl md:text-5xl font-extrabold text-brand-900 mb-6 leading-tight ${post.type === 'Audit' ? 'text-left' : ''}`}>
          {post.title}
        </h1>
        <p class={`text-xl text-gray-600 max-w-2xl mx-auto leading-relaxed ${post.type === 'Audit' ? 'text-left ml-0' : ''}`}>
          {post.description}
        </p>
      </header>

      {isNewAudit && statsData && (
        <div class="not-prose my-16 space-y-12 border-b border-gray-100 pb-16">
          <h2 class="text-3xl md:text-5xl font-extrabold text-brand-900 leading-tight">
            A korábbi válaszaid szerint a konverziód kb. <span class="text-brand-accent">{statsData.conversionRate}%</span>. Ez azt jelenti, hogy havonta kb. <span class="text-brand-accent">{new Intl.NumberFormat('hu-HU').format(statsData.lostSales)}</span> látogatód fizetés nélkül távozik.
          </h2>

          <h2 class="text-3xl md:text-5xl font-extrabold text-brand-900 leading-tight">
            Mi történne, ha továbbra is ugyanannyit költenél hirdetésre, ugyanannyi látogatód lenne, de <span class="underline decoration-brand-accent">növelnénk</span> azok számát, akik fizetnek is?
          </h2>

          <div class="overflow-x-auto rounded-2xl border border-gray-200">
            <table class="w-full text-left border-collapse bg-white">
              <thead>
                <tr class="bg-gray-50 border-b border-gray-200">
                  <th class="py-5 px-6 text-lg font-bold text-brand-900">Konverzió növekedés</th>
                  <th class="py-5 px-6 text-lg font-bold text-brand-900">Plusz Bevétel</th>
                  <th class="py-5 px-6 text-lg font-bold text-brand-900">Összesen</th>
                </tr>
              </thead>
              <tbody>
                {statsData.projections.map((proj) => (
                  <tr class="border-b border-gray-100 last:border-0 hover:bg-gray-50/50 transition-colors">
                    <td class="py-5 px-6 text-lg font-semibold text-gray-900">{proj.increase}</td>
                    <td class="py-5 px-6 text-xl font-bold text-brand-accent">{proj.extraRevenue}</td>
                    <td class="py-5 px-6 text-lg text-gray-600">{proj.total}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <h2 class="text-3xl md:text-5xl font-extrabold text-brand-900 leading-tight">
            Ezek alapján minden hónapban minimum <span class="text-brand-accent">{statsData.projections[0].extraRevenue}</span>-ot veszítesz.
          </h2>
        </div>
      )}

      {post.coverImage && (
        <div class="mb-12 rounded-2xl overflow-hidden shadow-lg aspect-video">
          <Image 
            src={post.coverImage} 
            alt={post.title} 
            width={1200} 
            height={675} 
            class="w-full h-full object-cover"
            loading="eager" 
          />
        </div>
      )}

      <div class="prose prose-lg prose-slate mx-auto max-w-none prose-headings:font-bold prose-headings:text-brand-900 prose-p:text-gray-700 prose-a:text-brand-accent prose-a:no-underline hover:prose-a:underline prose-strong:text-brand-900 prose-li:text-gray-700">
        <div set:html={optimizedContent} />
      </div>

      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        "headline": post.title,
        "description": post.description,
        "image": post.coverImage ? [post.coverImage] : [],
        "datePublished": post.publishedDate.toISOString(),
        "author": {
          "@type": "Person",
          "name": "Bogdán Norbert"
        }
      })} />
    </article>
  </main>

  {post.type === 'Audit' ? (
    <MainWebsiteCloser client:visible />
  ) : (
    <DefaultCloser client:visible />
  )}

  <style is:global>
    /* Ensure any embedded forms/iframes (like Formbricks) have a transparent background */
    .prose iframe {
      background-color: transparent !important;
      border: none !important;
      color-scheme: light;
      max-width: 100%;
      min-height: 450px; 
      width: 100%;
      overflow: hidden;
    }

    @media (max-width: 640px) {
      .prose iframe {
        min-height: 550px; /* Larger fallback for mobile */
      }
    }
    
    /* Target Formbricks specific elements to remove background and extra spacing */
    div#formbricks-container, 
    div#formbricks-container > iframe,
    .formbricks-form-container {
      background-color: transparent !important;
      background: transparent !important;
    }

    /* Ensure the container injected from Notion doesn't restrict height */
    .prose div:has(> iframe) {
      height: auto !important;
      min-height: min-content !important;
      overflow: visible !important;
    }
  </style>

  <script is:inline>
    // Robust listener for height messages from Formbricks
    window.addEventListener('message', (event) => {
      // Security: Only listen to your own form domain
      if (!event.origin.includes('form.designter.hu')) return;
      
      try {
        const data = typeof event.data === 'string' ? JSON.parse(event.data) : event.data;
        
        // Formbricks sends height in various message types
        const height = data.height || 
                       (data.data && data.data.height) || 
                       (data.payload && data.payload.height);

        if (height && height > 0) {
          const iframes = document.querySelectorAll('iframe');
          for (const iframe of iframes) {
            // Check if this is the iframe that sent the message
            if (iframe.contentWindow === event.source || iframe.src.includes(event.origin)) {
              // Apply height with a generous buffer for mobile (60px)
              const newHeight = (height + 60) + 'px';
              iframe.style.setProperty('height', newHeight, 'important');
              
              // Force parent containers to expand
              let parent = iframe.parentElement;
              while (parent && parent !== document.body) {
                if (parent.tagName === 'DIV') {
                  parent.style.setProperty('height', 'auto', 'important');
                  parent.style.setProperty('min-height', newHeight, 'important');
                }
                parent = parent.parentElement;
              }
              
              // Ensure scrolling is disabled to force the height to be correct
              iframe.scrolling = 'no';
              iframe.style.overflow = 'hidden';
            }
          }
        }
      } catch (e) {
        // Not a valid JSON or other message, ignore silently
      }
    }, false);
  </script>
</Layout>
