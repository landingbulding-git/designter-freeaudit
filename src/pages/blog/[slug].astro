---
import Layout from '../../layouts/Layout.astro';
import { getPublishedBlogPosts } from '../../lib/notion';
import { Image, getImage } from 'astro:assets';
import { marked } from 'marked';
import { load } from 'cheerio';
import { MousePointer2 } from 'lucide-react';
import DefaultCloser from '../../components/ingyenes-audit/Closer';
import MainWebsiteCloser from '../../components/main-website/Closer';

export async function getStaticPaths() {
  const posts = await getPublishedBlogPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const contentHtml = await marked.parse(post.content || '');

// Process HTML to optimize images using Astro's getImage
const $ = load(contentHtml);
let customReadingTime = null;

if (post.type === 'Audit') {
  // 2. Embed HTML blocks
  $('pre code.language-html').each((i, el) => {
    const rawHtml = $(el).text();
    $(el).parent().replaceWith(rawHtml);
  });

  // 4. Extract reading time
  $('p').each((i, el) => {
    const text = $(el).text();
    if (text.includes('Olvasási idő:')) {
      customReadingTime = text;
      $(el).remove();
    }
  });

  // 5. Format signature
  let signatureTextsFound = false;
  let $name, $role, $button, $img;

  $('p').each((i, el) => {
    const text = $(el).text().trim();
    if (text === 'Bogdán Norbert') {
      $name = $(el);
      signatureTextsFound = true;
    } else if (text === 'CRO Specialista | DesignTér') {
      $role = $(el);
    } else if (text.includes('Beszéljünk 15 percet')) {
      $button = $(el);
    }
  });

  if (signatureTextsFound) {
    // Assume the image is immediately preceding the name, or fallback to the last image in the document
    $img = $name.prev('img');
    if (!$img.length) {
       $img = $name.prev().find('img');
    }
    if (!$img.length) {
       $img = $('img').last(); 
    }

    const $signatureContainer = $('<div class="not-prose my-16 p-6 sm:p-8 bg-gray-50 rounded-3xl border border-gray-100 shadow-sm w-full"></div>');
    const $signatureInner = $('<div class="flex flex-col sm:flex-row items-center gap-6 sm:gap-8 w-full"></div>');

    if ($img.length) {
      $img.attr('data-signature', 'true');
      const $imgContainer = $('<div class="flex-shrink-0 w-24 h-24 sm:w-28 sm:h-28 rounded-full overflow-hidden border-4 border-white shadow-md"></div>');
      // Clone the img so we can place it in our new container
      $imgContainer.append($img.clone());
      $signatureInner.append($imgContainer);
      $img.remove(); // Remove original
    }

    const $contentWrapper = $('<div class="flex flex-col lg:flex-row lg:items-center justify-between w-full gap-6"></div>');
    const $textWrapper = $('<div class="flex flex-col items-center sm:items-start text-center sm:text-left"></div>');
    const $rightColumn = $('<div class="flex flex-col items-center lg:items-end gap-3 w-full lg:w-auto"></div>');

    if ($name) {
      $name.addClass('text-2xl font-bold text-gray-900 mb-1 mt-0');
      $textWrapper.append($name.clone());
      $name.remove();
    }
    if ($role) {
      $role.addClass('text-base text-gray-500 m-0');
      $textWrapper.append($role.clone());
      $role.remove();
    }
    
    if ($button) {
      const $a = $button.find('a').length ? $button.find('a') : $button;
      $a.addClass('inline-flex justify-center items-center w-full lg:w-auto bg-brand-accent text-white font-semibold px-8 py-3.5 rounded-xl hover:bg-brand-900 transition-colors shadow-sm decoration-transparent');
      if ($button.is('p') && $button.find('a').length) {
        $rightColumn.append($a.clone());
        $button.remove();
      } else {
        $rightColumn.append($a.clone());
        $button.remove();
      }
    }

    // Add the highlighted free consultation text with light mode friendly green colors
    const $guarantee = $(`
      <div class="flex items-center justify-center sm:justify-start gap-2 p-3 bg-green-500/10 rounded-lg border border-green-500/20 w-full lg:w-fit">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-green-600 flex-shrink-0"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        <p class="text-xs sm:text-sm font-bold text-green-700 text-center m-0">A konzultáció 100%-ban ingyenes és kötelezettségmentes.</p>
      </div>
    `);

    $rightColumn.append($guarantee);

    $contentWrapper.append($textWrapper);
    $contentWrapper.append($rightColumn);
    
    $signatureInner.append($contentWrapper);
    $signatureContainer.append($signatureInner);
    
    // Move signature below the specific intro sentence
    let $introSentence = null;
    $('p, strong').each((i, el) => {
      if ($(el).text().includes('vizuális prototípust is kifejezetten nektek')) {
        $introSentence = $(el).closest('p');
        return false;
      }
    });

    if ($introSentence && $introSentence.length) {
      $signatureContainer.insertAfter($introSentence);
    } else {
      $('body').append($signatureContainer);
    }
  }

  // 6. Format FAQ Toggles (H3 followed by indented text parsed as code block)
  $('h3').each((i, el) => {
    const $h3 = $(el);
    const $next = $h3.next();
    
    // Check if the next element is a code block
    if ($next.is('pre') && $next.find('code').length > 0) {
      const questionHtml = $h3.html();
      const answerText = $next.find('code').text().trim();
      
      const $details = $(`
        <details class="group bg-white rounded-2xl shadow-sm border border-gray-100 p-6 mb-4 cursor-pointer [&_summary::-webkit-details-marker]:hidden not-prose">
          <summary class="flex items-center justify-between font-bold text-lg text-brand-900 list-none hover:text-brand-accent transition-colors outline-none">
            <span class="pr-4">${questionHtml}</span>
            <span class="flex-shrink-0 transition-transform duration-300 group-open:-rotate-180 bg-gray-50 p-2 rounded-full group-hover:bg-brand-50">
              <svg fill="none" height="20" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="20" class="text-brand-accent"><path d="M6 9l6 6 6-6"></path></svg>
            </span>
          </summary>
          <div class="text-gray-600 mt-4 leading-relaxed pl-2 border-l-2 border-brand-accent/20">
            ${answerText}
          </div>
        </details>
      `);
      
      $h3.replaceWith($details);
      $next.remove();
    }
  });
}

const imgElements = $('img');

await Promise.all(imgElements.map(async (i, el) => {
  const src = $(el).attr('src');
  if (!src) return;

  const isSignature = $(el).attr('data-signature') === 'true';

  try {
    const optimized = await getImage({
      src: src,
      format: 'webp',
      width: isSignature ? 256 : 800, // Resize to a reasonable width for blog content
      height: isSignature ? 256 : undefined, // Maintain aspect ratio
    });
    
    $(el).attr('src', optimized.src);
    $(el).attr('loading', 'lazy');
    $(el).attr('decoding', 'async');
    // Add Tailwind classes for styling
    if (isSignature) {
      $(el).addClass('w-full h-full object-cover');
    } else {
      $(el).addClass('rounded-xl shadow-lg my-8 w-full h-auto object-cover');
    }
    // Remove fixed dimensions if any
    $(el).removeAttr('width');
    $(el).removeAttr('height');
  } catch (e) {
    console.error(`Failed to optimize image: ${src}`, e);
    // Fallback: just add styling
    $(el).attr('loading', 'lazy');
    if (isSignature) {
      $(el).addClass('w-full h-full object-cover');
    } else {
      $(el).addClass('rounded-xl shadow-lg my-8 w-full h-auto object-cover');
    }
  }
}).get());

const optimizedContent = $('body').html() || contentHtml; // Extract body content or fallback

const title = `${post.title} - DesignTér Blog`;
const description = post.description;
---

<Layout title={title} description={description}>
  <header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-100 py-4">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex justify-between items-center">
      <a href="/blog" class="flex items-center gap-2 group text-gray-600 hover:text-brand-900 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        <span class="font-medium">Vissza a blogra</span>
      </a>
      <a href="/" class="flex items-center gap-2">
        <div class="bg-brand-accent p-1.5 rounded-lg">
          <MousePointer2 className="w-5 h-5 text-white" />
        </div>
        <span class="text-lg font-bold tracking-tight text-brand-900 hidden sm:inline">DesignTér</span>
      </a>
    </div>
  </header>

  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <article>
      <header class={`mb-8 ${post.type === 'Audit' ? 'text-left' : 'text-center'}`}>
        <div class={`flex items-center ${post.type === 'Audit' ? 'justify-start' : 'justify-center'} gap-4 text-sm text-gray-500 mb-4`}>
          <time datetime={post.publishedDate.toISOString()}>
            {post.publishedDate.toLocaleDateString('hu-HU', { 
              year: 'numeric', 
              month: 'long', 
              day: 'numeric' 
            })}
          </time>
          {post.type !== 'Audit' ? (
            <>
              <span>•</span>
              <span>{Math.ceil(post.content.split(' ').length / 200)} perc olvasás</span>
            </>
          ) : (
            customReadingTime && (
              <span class="bg-brand-accent/10 text-brand-900 font-medium px-3 py-1 rounded-full text-xs">
                {customReadingTime}
              </span>
            )
          )}
        </div>
        <h1 class={`text-3xl md:text-5xl font-extrabold text-brand-900 mb-6 leading-tight ${post.type === 'Audit' ? 'text-left' : ''}`}>
          {post.title}
        </h1>
        <p class={`text-xl text-gray-600 max-w-2xl mx-auto leading-relaxed ${post.type === 'Audit' ? 'text-left ml-0' : ''}`}>
          {post.description}
        </p>
      </header>

      {post.coverImage && (
        <div class="mb-12 rounded-2xl overflow-hidden shadow-lg aspect-video">
          <Image 
            src={post.coverImage} 
            alt={post.title} 
            width={1200} 
            height={675} 
            class="w-full h-full object-cover"
            loading="eager" 
          />
        </div>
      )}

      <div class="prose prose-lg prose-slate mx-auto max-w-none prose-headings:font-bold prose-headings:text-brand-900 prose-p:text-gray-700 prose-a:text-brand-accent prose-a:no-underline hover:prose-a:underline prose-strong:text-brand-900 prose-li:text-gray-700">
        <div set:html={optimizedContent} />
      </div>

      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        "headline": post.title,
        "description": post.description,
        "image": post.coverImage ? [post.coverImage] : [],
        "datePublished": post.publishedDate.toISOString(),
        "author": {
          "@type": "Person",
          "name": "Bogdán Norbert"
        }
      })} />
    </article>
  </main>

  {post.type === 'Audit' ? (
    <MainWebsiteCloser client:visible />
  ) : (
    <DefaultCloser client:visible />
  )}

  <style is:global>
    /* Ensure any embedded forms/iframes (like Formbricks) have a transparent background */
    .prose iframe {
      background-color: transparent !important;
      border: none !important;
      color-scheme: light; /* Helps Formbricks know to stay transparent/light */
      max-width: 100%;
      height: auto;
      min-height: 400px; /* Give it enough space to render but not infinite */
    }
    
    /* Target Formbricks specific elements to remove background and extra spacing */
    div#formbricks-container, 
    div#formbricks-container > iframe,
    .formbricks-form-container {
      background-color: transparent !important;
      background: transparent !important;
    }

    /* Remove extra margins from the embed container if it's nested in prose */
    .prose > div:has(iframe) {
      margin-top: 0 !important;
      margin-bottom: 0 !important;
    }
  </style>
</Layout>
